# =============================================
# CODEWEBSEPT - Fichiers à ignorer par Git
# =============================================

# ----------------------------------------------
# Fichier spécifique personnel
# ----------------------------------------------
Euh Comment Ss7.txt

# ----------------------------------------------
# Fichiers temporaires et logs
# ----------------------------------------------
*.log
*.tmp
*.temp
*.bak
*.swp
*~

# ----------------------------------------------
# Dépendances Node.js
# ----------------------------------------------
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# ----------------------------------------------
# Dossiers de build/compilation
# ----------------------------------------------
dist/
build/
.cache/
.parcel-cache/
.vite/

# ----------------------------------------------
# Fichiers système macOS
# ----------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*

# ----------------------------------------------
# Fichiers système Windows
# ----------------------------------------------
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini

# ----------------------------------------------
# Fichiers système Linux
# ----------------------------------------------
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ----------------------------------------------
# Fichiers d'environnement (secrets)
# ----------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# ----------------------------------------------
# IDE et éditeurs
# ----------------------------------------------
# Visual Studio Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains (WebStorm, PhpStorm, etc.)
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# ----------------------------------------------
# Fichiers de débogage
# ----------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ----------------------------------------------
# Fichiers de test
# ----------------------------------------------
coverage/
.nyc_output/

# ----------------------------------------------
# Minification / Compression (si générés)
# ----------------------------------------------
*.min.js
*.min.css
*.map

# ----------------------------------------------
# Fichiers de sauvegarde
# ----------------------------------------------
*.backup
*.old

# ----------------------------------------------
# Archives
# ----------------------------------------------
*.zip
*.tar.gz
*.rar
*.7z